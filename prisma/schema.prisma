generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  image         String?
  password      String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Story {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName          String
  relationship      String
  contactNumber     String
  email             String?
  city              String
  category          String
  storyDescription  String
  contactPreference String
  identityProofUrl  String?
  relevantDocsUrl   String?
  hospitalDocsUrl   String?
  otherDocsUrl      String?
  status            String    @default("pending") // pending, query, approved, promotion, rejected
  assignedTo        String?
  priority          String?
  promotionDays     String?
  promotionPlatforms String[]
  
  // Workflow fields
  queryMessage      String?
  queryResponse     String?
  queryResponseDocs String[]  @default([])
  approvalNote      String?
  promotionStartDate DateTime?
  promotionEndDate   DateTime?
  campaignStatus    String?
  reach             Int?
  clicks            Int?
  engagement        Int?
  videoViews        Int?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}
